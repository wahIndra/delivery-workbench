#!/bin/sh
# Licensed to the Apache Software Foundation (ASF) under one or more contributor license agreements.
# Minimal Maven Wrapper script for Docker builds.

set -e

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
    DISTRIBUTION_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)
fi

# If mvn is on path, use it directly (handles corporate environments)
if command -v mvn > /dev/null 2>&1; then
    exec mvn "$@"
fi

echo "Maven not found. Please install Maven 3.9+ or ensure mvn is on PATH."
exit 1
