# ──────────────────────────────────────────────────────────────
# IT Delivery Workbench — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Database
DB_NAME=deliveryworkbench
DB_USERNAME=dwuser
DB_PASSWORD=change-this-password
DB_PORT=5432

# Backend
SERVER_PORT=8080
BACKEND_PORT=8080

# JWT — MUST be at least 32 characters in production
JWT_SECRET=change-this-secret-in-production-minimum-32-chars
JWT_EXPIRATION_MS=86400000

# CORS — comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
